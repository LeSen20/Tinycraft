              onChange={(e) => setNameInput(e.target.value)}
              onKeyDown={(e) => e.key === "Enter" && nameInput.trim() && saveMe({ name: nameInput.trim(), memberships: [] })}
            />
            <button
              style={{ ...bevelGreen, marginTop: 12, opacity: nameInput.trim() ? 1 : 0.5 }}
