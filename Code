                const th = THEMES[k];
                const sel = k === themeKey;
                return (
                  <button key={k} onClick={() => saveTheme(k)}
                    style={{
                      ...S.btn, flexShrink: 0, display: "flex", alignItems: "center", gap: 7,
                      padding: "6px 12px", fontWeight: sel ? 600 : 400,
                      borderColor: sel ? th.accent : T.border,
                      boxShadow: sel ? `0 0 0 2px ${th.accent}55` : "none",
                    }}>
                    <span style={{ display: "inline-flex", borderRadius: 999, overflow: "hidden", border: `1px solid ${T.border}` }}>
                      <span style={{ width: 11, height: 16, background: th.bg }} />
                      <span style={{ width: 11, height: 16, background: th.surface }} />
                      <span style={{ width: 11, height: 16, background: th.accent }} />
                    </span>
                    {th.name}
                  </button>
                );
