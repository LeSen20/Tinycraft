            <div className="flex items-center gap-2 overflow-x-auto pb-1" style={{ flexWrap: "nowrap", touchAction: "pan-x", WebkitOverflowScrolling: "touch", overscrollBehavior: "contain" }}>
              {[...privMarkers.map((m) => ({ ...m, kind: "privat" })), ...clanMarkers.filter((m) => isMember(m.clanId)).map((m) => ({ ...m, kind: "clan" }))].map((m) => {
                const clan = m.kind === "clan" ? clans.find((c) => c.id === m.clanId) : null;
                return (
                  <span key={m.id} className="flex items-center" style={{ flexShrink: 0 }}>
                    <button
                      style={{ ...S.btn, padding: "3px 8px", fontSize: 16, whiteSpace: "nowrap", borderRight: "none", background: T.text2 }}
                      onClick={() => { if (m.dim !== dimKey) setDimKey(m.dim); setTimeout(() => centerOn(m.x, m.z), 0); setPanelOpen(false); }}>
                      <Flag size={12} className="inline mr-1" style={{ color: clan ? clan.color : T.accent }} />
                      {m.name} ({m.kind === "privat" ? "privat" : clan ? clan.name : "?"} · {DIMS[m.dim].label} · X {m.x} / Z {m.z})
                    </button>
                    <button style={{ ...S.btn, padding: "3px 6px", fontSize: 14, background: T.danger, color: T.text }}
                      title="Marker löschen" onClick={() => deleteMarker(m)}><X size={12} /></button>
                  </span>
                );
              })}
            </div>
            {privMarkers.length + clanMarkers.filter((m) => isMember(m.clanId)).length === 0 && (
              <div style={{ color: T.dim }}>Keine Marker sichtbar.</div>
            )}
            <div className="text-sm font-semibold uppercase tracking-wide mt-5 mb-2" style={{ color: T.dim }}>
              Mit anderen teilen
            </div>
            <div className="text-sm mb-2" style={{ color: T.text2 }}>
              {sharedWorks
                ? "Änderungen werden automatisch mit allen geteilt."
                : "Automatisches Teilen geht hier nicht. Erstelle einen Code und schick ihn den anderen – sie fügen ihn unten ein."}
            </div>
            <div className="flex gap-2 mb-2">
              <button onClick={machTeilenCode} style={{ ...S.btn, padding: "7px 14px" }}>Code erstellen</button>
              <button onClick={nimmTeilenCode} disabled={!shareCode.trim()}
                style={{ ...S.btn, padding: "7px 14px", opacity: shareCode.trim() ? 1 : 0.5 }}>
                Code übernehmen
              </button>
            </div>
            <textarea
              value={shareCode}
              onChange={(e) => setShareCode(e.target.value)}
              placeholder="Teilen-Code hier einfügen oder erstellen lassen"
              rows={3}
              style={{ ...S.input, resize: "none", fontSize: 12, fontFamily: "ui-monospace, monospace" }}
            />

            <button onClick={speicherTest}
              style={{ ...S.btn, padding: "7px 14px", marginTop: 14 }}>
              Speicher-Selbsttest
            </button>

            <div className="text-sm mt-3" style={{ color: T.dim }}>
              Clans und Gebiete sind für alle sichtbar. Private Marker sieht nur dein Konto, Clan-Marker nur Clan-Mitglieder.
              Änderungen anderer erscheinen automatisch nach wenigen Sekunden.
            </div>
          </div>
        )}

        {/* Legende */}
        {!panelOpen && !sel && clans.length > 0 && (
          <div className="absolute bottom-2 right-2 p-2 overflow-y-auto" style={{ ...S.panel, maxWidth: "46%", maxHeight: "38%" }}>
            <div className="text-base" style={{ color: T.accent }}>Clans</div>
            {clans.map((c) => (
              <div key={c.id}>
                <div className="flex items-center gap-1 text-base">
                  <span className="inline-block w-3 h-3" style={{ background: c.color }} />
                  <span style={{ color: c.color }}>{c.name}</span>
                </div>
                {isMember(c.id) && c.description && <div className="text-xs ml-4" style={{ color: T.dim }}>{c.description}</div>}
              </div>
            ))}
          </div>
        )}

        {/* Auswahl-Info */}
        {sel && (() => {
          const isTerr = sel.type === "terr";
          const t = sel.obj;
          const clan = isTerr ? clans.find((c) => c.id === t.clanId) : (t.kind === "clan" ? clans.find((c) => c.id === t.clanId) : null);
          const col = isTerr ? (clan ? clan.color : T.border) : T.accent;
          const restricted = isTerr && !isMember(t.clanId);
          const mayDelete = isTerr ? isMember(t.clanId) : true;
          return (
            <div className="absolute left-2 right-2 bottom-2 p-2" style={{ background: T.overlay, border: `1px solid ${col}`, borderRadius: 14, boxShadow: "0 10px 30px rgba(0,0,0,.35)" }}>
              <div className="text-lg" style={{ color: col }}>
                {restricted ? `Gebiet von ${clan ? clan.name : "?"}` : isTerr ? t.label : "📍 " + t.name}
              </div>
              {restricted ? (
                <div className="text-base" style={{ color: T.dim }}>
                  Nur Mitglieder von „{clan ? clan.name : "?"}“ sehen Details zu diesem Gebiet.
                  Tritt dem Clan im Clans-Menü mit dem Codewort bei.
                </div>
              ) : (
                <>
                  <div className="text-base">
                    {isTerr
                      ? `Clan: ${clan ? clan.name : "?"} · ${DIMS[t.dim].label} · Mitte X ${t.x} / Z ${t.z} · Radius ${t.r || TERR_RADIUS} Blöcke`
                      : `${t.kind === "privat" ? "Privater Marker" : "Clan-Marker (" + (clan ? clan.name : "?") + ")"} · ${DIMS[t.dim].label} · X ${t.x} / Z ${t.z}`}
                    {t.by ? ` · von ${t.by}` : ""}
                  </div>
                  {isTerr && clan && clan.description && <div className="text-base" style={{ color: T.text2 }}>{clan.description}</div>}
                </>
              )}
              <div className="flex gap-2 mt-1">
                {mayDelete && (
                  <button style={{ ...S.btn, padding: "3px 10px", fontSize: 16, background: T.danger, color: T.text }}
                    onClick={() => (isTerr ? deleteTerr(t) : deleteMarker(t))}>
                    Löschen
                  </button>
                )}
                <button style={{ ...S.btn, padding: "3px 10px", fontSize: 16 }} onClick={() => setSel(null)}>Schließen</button>
              </div>
            </div>
          );
        })()}

        {/* Marker-Dialog */}
        {markerDlg && (
          <div className="absolute left-2 right-2 bottom-2 p-2" style={{ background: T.overlay, border: `1px solid ${T.accent}`, borderRadius: 14, boxShadow: "0 10px 30px rgba(0,0,0,.35)" }}>
            <div className="text-lg" style={{ color: T.accent }}>Marker am Fadenkreuz setzen (X {cw.x} / Z {cw.z})</div>
            <input style={S.input} className="my-1" placeholder="Name (z.B. Basis, Portal, Farm)" maxLength={40}
              value={markerName} onChange={(e) => setMarkerName(e.target.value)}
              onKeyDown={(e) => e.key === "Enter" && saveMarker()} />
            <div className="flex gap-1 flex-wrap my-1">
              <button style={{ ...S.btn, padding: "3px 10px", fontSize: 16, ...(markerVis === "privat" ? S.btnActive : {}) }} onClick={() => setMarkerVis("privat")}>Privat</button>
              {myClans.map((c) => (
                <button key={c.id} style={{ ...S.btn, padding: "3px 10px", fontSize: 16, ...(markerVis === c.id ? { background: c.color, color: T.text } : {}) }} onClick={() => setMarkerVis(c.id)}>
                  Clan: {c.name}
                </button>
              ))}
            </div>
            <div className="flex gap-2">
              <button style={{ ...S.btn, padding: "3px 12px", fontSize: 16 }} onClick={saveMarker}>Setzen</button>
              <button style={{ ...S.btn, padding: "3px 12px", fontSize: 16 }} onClick={() => setMarkerDlg(false)}>Abbrechen</button>
            </div>
          </div>
        )}

        {storageBroken && !bannerZu && !note && (
          <div className="absolute top-2 left-2 right-2 px-3 py-2 text-sm"
            style={{ background: T.overlay, border: `1px solid ${T.danger}`, borderRadius: 12, color: T.text2 }}>
