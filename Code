        <div className="flex flex-col items-center text-center max-w-sm w-full">
          <PixelCompass size={88} />
          <div style={{ fontSize: 40, fontWeight: 700, letterSpacing: -1, color: T.text }} className="mt-4">
            TINYCRAFT
          </div>
          <div className="text-xl mt-1" style={{ color: T.dim }}>Die gemeinsame Karte für euren Server</div>

          <div style={{ ...S.panel }} className="p-5 w-full mt-6">
