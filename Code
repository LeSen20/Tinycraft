/* Wenn der gemeinsame Speicher nicht schreiben kann, wird automatisch der
   persoenliche benutzt - dann bleiben die Daten wenigstens auf dem Geraet. */
let SHARED_OK = true;
let lastStorageError = "";
function storageOk() {
  return typeof window !== "undefined" && window.storage && typeof window.storage.set === "function";
}
function eff(shared) { return shared && SHARED_OK; }

/* Ein noch nicht vorhandener Eintrag meldet hier einen Fehler statt "leer".
   Das ist normal und darf nicht als Speicherproblem gewertet werden. */
async function sGet(key, shared) {
  if (!storageOk()) return null;
  try {
    const r = await window.storage.get(key, eff(shared));
    if (r && r.value) return JSON.parse(r.value);
  } catch (e) {}
  return null;
}

async function sGetRaw(key, shared) {
  if (!storageOk()) return null;
  try {
    const r = await window.storage.get(key, eff(shared));
    return r && typeof r.value === "string" ? r.value : null;
  } catch (e) {}
  return null;
}

async function sSet(key, val, shared) {
  if (!storageOk()) { lastStorageError = "window.storage fehlt"; return false; }
  const json = JSON.stringify(val);
  try {
    await window.storage.set(key, json, eff(shared));
    return true;
  } catch (e) {
    lastStorageError = e && e.message ? e.message : String(e);
    // Manche Umgebungen melden einen Fehler, obwohl geschrieben wurde -> nachlesen
    const zurueck = await sGetRaw(key, eff(shared));
    if (zurueck === json) { lastStorageError = ""; return true; }
    return false;
  }
}
/* Liest den aktuellen Stand, wendet fn an, speichert - reduziert Ueberschreib-Konflikte */
async function mutateShared(key, fallback, fn) {
  const cur = (await sGet(key, true)) ?? fallback;
  const next = fn(cur);
  await sSet(key, next, true);
  return next;
}

/* Karten sind zu gross fuer einen Speichereintrag -> in Teilstuecke zerlegen */
const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

/* Der Speicher lehnt Werte mit / und + ab -> Bilddaten umkodieren */
function toSafeB64(dataUrl) {
  const i = dataUrl.indexOf(",");
  return dataUrl.slice(i + 1).replace(/\+/g, "-").replace(/\//g, "_");
}
function fromSafeB64(s) {
  return "data:image/jpeg;base64," + s.replace(/-/g, "+").replace(/_/g, "/");
}

async function saveMapImage(dimKey, dataUrl, chunkSize, pause, onProgress) {
  // Erst pruefen, ob ueberhaupt geschrieben werden darf
  const test = await sSet(K.mapMeta(dimKey) + "t", 1, true);
  if (!test) throw new Error(lastStorageError || "Speicher antwortet nicht");

  const payload = toSafeB64(dataUrl);
  const parts = [];
  for (let i = 0; i < payload.length; i += chunkSize) parts.push(payload.slice(i, i + chunkSize));
  for (let i = 0; i < parts.length; i++) {
    let ok = false;
    for (let versuch = 0; versuch < 3 && !ok; versuch++) {
      ok = await sSet(K.mapPart(dimKey, i), parts[i], true);
      if (!ok) await sleep(1200 * (versuch + 1));
    }
    if (!ok) throw new Error(`Teil ${i + 1} von ${parts.length}`);
    if (onProgress) onProgress(i + 1, parts.length);
    if (i < parts.length - 1) await sleep(pause);
  }
  const ok = await sSet(K.mapMeta(dimKey), { parts: parts.length, safe: true }, true);
  if (!ok) throw new Error("Kartenverzeichnis");
}

async function loadMapImage(dimKey) {
  const meta = await sGet(K.mapMeta(dimKey), true);
  if (meta && meta.parts) {
    let out = "";
    for (let i = 0; i < meta.parts; i++) {
      const p = await sGet(K.mapPart(dimKey, i), true);
      if (typeof p !== "string") return null; // unvollstaendig
      out += p;
    }
    return meta.safe ? fromSafeB64(out) : out;
  }
  const old = await sGet(K.map(dimKey), true); // Rueckwaertskompatibel
  return typeof old === "string" ? old : null;
}

function fileToDataUrl(file, maxDim, maxBytes) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onerror = reject;
    reader.onload = () => {
      const img = new Image();
      img.onerror = reject;
      img.onload = () => {
        let w = img.naturalWidth, h = img.naturalHeight;
        if (Math.max(w, h) > maxDim) {
          const s = maxDim / Math.max(w, h);
          w = Math.round(w * s); h = Math.round(h * s);
        }
        const c = document.createElement("canvas");
        c.width = w; c.height = h;
        c.getContext("2d").drawImage(img, 0, 0, w, h);
        let q = 0.9;
        let url = c.toDataURL("image/jpeg", q);
        while (url.length > maxBytes && q > 0.4) {
          q -= 0.1;
          url = c.toDataURL("image/jpeg", q);
        }
        if (url.length > maxBytes) reject(new Error("zu_gross"));
        else resolve(url);
      };
      img.src = reader.result;
    };
    reader.readAsDataURL(file);
  });
}

