            <input style={S.input} className="mb-1" placeholder="Codewort zum Beitreten" maxLength={40} value={newClan.code} onChange={(e) => setNewClan({ ...newClan, code: e.target.value })} />
            <textarea style={{ ...S.input, resize: "none" }} rows={2} placeholder="Beschreibung (optional)" value={newClan.desc} onChange={(e) => setNewClan({ ...newClan, desc: e.target.value })} />
            <div className="flex gap-1 my-2 flex-wrap">
              {CLAN_COLORS.map((c) => (
                <button key={c} className="w-8 h-8" style={{ borderRadius: 999, background: c, border: newClan.color === c ? `2px solid ${T.text}` : "2px solid transparent" }} onClick={() => setNewClan({ ...newClan, color: c })} />
