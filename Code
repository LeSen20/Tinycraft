    setTerrs((prev) => (Array.isArray(t) ? t : prev));
    setClanMarkers((prev) => (Array.isArray(m) ? m : prev));
    setSyncing(false);
  }, []);

  useEffect(() => {
    (async () => {
      const th = await sGet("tc2:theme", false);
      if (typeof th === "string" && THEMES[th]) setThemeKey(th);
      const meData = await sGet(K.me, false);
      if (meData && meData.name) setMe({ memberships: [], ...meData });
      const pm = await sGet(K.privMarkers, false);
      setPrivMarkers(Array.isArray(pm) ? pm : []);
      setMapUrls({ ...EMBEDDED_MAPS });
      await loadShared();
      let schreibbar = await sSet("tc2:probe", Date.now(), true);
      if (!schreibbar) {
        SHARED_OK = false; // gemeinsamer Speicher geht nicht -> persoenlich versuchen
        schreibbar = await sSet("tc2:probe", Date.now(), false);
      }
      setSharedWorks(SHARED_OK && schreibbar);
      setStorageBroken(!schreibbar);
      setLoading(false);
    })();
  }, [loadShared]);

  /* Alle 12s den geteilten Stand nachladen, damit Aenderungen anderer sichtbar werden */
  useEffect(() => {
    const iv = setInterval(loadShared, 12000);
    return () => clearInterval(iv);
  }, [loadShared]);

  /* Bilder aus dataUrls aufbauen */
  useEffect(() => {
    for (const d of DIM_KEYS) {
      if (mapUrls[d] && !imgs[d]) {
        const im = new Image();
        im.onload = () => {
          // Massstab aus der echten Bildbreite ableiten, damit 0/0 immer stimmt
          if (im.width > 0) DIMS[d].blocksPerPx = DIMS[d].worldSpan / im.width;
          setImgs((p) => ({ ...p, [d]: im }));
        };
        im.src = mapUrls[d];
      }
    }
  }, [mapUrls, imgs]);

  const img = imgs[dimKey] || null;

  /* ---------------- Geometrie ---------------- */

  const originPx = () => (0 - dim.worldMin) / dim.blocksPerPx;
  const chunkImgPx = () => 16 / dim.blocksPerPx;
  const worldToImg = (wx, wz) => ({ ix: (wx - dim.worldMin) / dim.blocksPerPx, iy: (wz - dim.worldMin) / dim.blocksPerPx });

  function clampCenter(cx, cy) {
    const lo = (dim.worldLo - dim.worldMin) / dim.blocksPerPx;
    const hi = (dim.worldHi - dim.worldMin) / dim.blocksPerPx;
    return { cx: clamp(cx, lo, hi), cy: clamp(cy, lo, hi) };
  }
  function centerWorld() {
    return {
      x: Math.round(dim.worldMin + view.cx * dim.blocksPerPx),
      z: Math.round(dim.worldMin + view.cy * dim.blocksPerPx),
    };
  }
  function fitView(targetImg) {
    const cv = canvasRef.current;
    const theImg = targetImg || img;
    if (!cv || !theImg) return;
    const s = Math.max(theImg.width / cv.width, theImg.height / cv.height) * 1.02;
    setView({ cx: theImg.width / 2, cy: theImg.height / 2, scale: s });
  }
  function homeView() {
    const cv = canvasRef.current;
    if (!cv) return;
    const s = Math.max(0.05, (250 * chunkImgPx()) / Math.min(cv.width, cv.height));
    const c = clampCenter(originPx(), originPx());
    setView({ cx: c.cx, cy: c.cy, scale: s });
  }
  function centerOn(wx, wz) {
    const p = worldToImg(wx, wz);
    const c = clampCenter(p.ix, p.iy);
    setView((v) => {
      const cv = canvasRef.current;
      let s = v.scale;
      if (cv) {
        const homeS = (250 * chunkImgPx()) / Math.min(cv.width, cv.height);
        if (s > homeS) s = homeS;
      }
      return { cx: c.cx, cy: c.cy, scale: s };
    });
  }

  /* ---------------- Zeichnen ---------------- */

  const draw = useCallback(() => {
    const cv = canvasRef.current;
    if (!cv) return;
    const ctx = cv.getContext("2d");
    const d = DIMS[dimRef.current];
    const v = viewRef.current;
    const theImg = imgs[dimRef.current];
    ctx.fillStyle = T.bg;
    ctx.fillRect(0, 0, cv.width, cv.height);
    if (!theImg) {
      ctx.fillStyle = T.dim;
      ctx.font = `${16 * devicePixelRatio}px Inter, system-ui, sans-serif`;
      ctx.textAlign = "center";
      ctx.fillText("Karte noch nicht hochgeladen", cv.width / 2, cv.height / 2);
      ctx.textAlign = "left";
      return;
    }
    ctx.imageSmoothingEnabled = v.scale >= 1;
    const sw = cv.width * v.scale, sh = cv.height * v.scale;
    const srcX = v.cx - sw / 2, srcY = v.cy - sh / 2;
    const cX = Math.max(0, srcX), cY = Math.max(0, srcY);
    const cX2 = Math.min(theImg.width, srcX + sw), cY2 = Math.min(theImg.height, srcY + sh);
    if (cX < cX2 && cY < cY2) {
      ctx.drawImage(theImg, cX, cY, cX2 - cX, cY2 - cY,
        (cX - srcX) / v.scale, (cY - srcY) / v.scale, (cX2 - cX) / v.scale, (cY2 - cY) / v.scale);
    }
    const toS = (ix, iy) => ({ sx: (ix - v.cx) / v.scale + cv.width / 2, sy: (iy - v.cy) / v.scale + cv.height / 2 });
    const w2i = (wx, wz) => ({ ix: (wx - d.worldMin) / d.blocksPerPx, iy: (wz - d.worldMin) / d.blocksPerPx });
    const dpr = devicePixelRatio;

    /* Chunk-Raster */
    if (showGrid) {
      const step = 16 / d.blocksPerPx;
      if (step / v.scale >= 5) {
        ctx.strokeStyle = "rgba(0,0,0,0.35)";
        ctx.lineWidth = 1;
        ctx.beginPath();
        const li = Math.max(0, v.cx - (cv.width / 2) * v.scale), ri = Math.min(theImg.width, v.cx + (cv.width / 2) * v.scale);
        const ti = Math.max(0, v.cy - (cv.height / 2) * v.scale), bi = Math.min(theImg.height, v.cy + (cv.height / 2) * v.scale);
        const y0 = Math.max(0, toS(0, 0).sy), y1 = Math.min(cv.height, toS(0, theImg.height).sy);
        const x0 = Math.max(0, toS(0, 0).sx), x1 = Math.min(cv.width, toS(theImg.width, 0).sx);
        for (let k = Math.ceil(li / step); k * step <= ri; k++) { const g = toS(k * step, 0).sx; ctx.moveTo(g, y0); ctx.lineTo(g, y1); }
        for (let k = Math.ceil(ti / step); k * step <= bi; k++) { const g = toS(0, k * step).sy; ctx.moveTo(x0, g); ctx.lineTo(x1, g); }
        ctx.stroke();
      }
    }

    /* Clan-Gebiete: Kreise mit 100 Bloecken Radius */
    for (const t of terrs) {
      if (t.dim !== dimRef.current) continue;
      const clan = clans.find((c) => c.id === t.clanId);
      if (!clan) continue;
      const p = w2i(t.x, t.z);
      const s = toS(p.ix, p.iy);
      const rPx = (t.r || TERR_RADIUS) / d.blocksPerPx / v.scale;
      if (s.sx + rPx < 0 || s.sy + rPx < 0 || s.sx - rPx > cv.width || s.sy - rPx > cv.height) continue;
      ctx.beginPath();
      ctx.arc(s.sx, s.sy, rPx, 0, Math.PI * 2);
      ctx.fillStyle = clan.color + "3D";
      ctx.fill();
      ctx.lineWidth = (sel && sel.type === "terr" && sel.obj.id === t.id ? 3 : 1.5) * dpr;
      ctx.strokeStyle = clan.color;
      ctx.stroke();
      ctx.beginPath();
      ctx.arc(s.sx, s.sy, 2 * dpr, 0, Math.PI * 2);
      ctx.fillStyle = clan.color;
      ctx.fill();
      if (rPx > 34 * dpr) {
        ctx.font = `${13 * dpr}px Inter, system-ui, sans-serif`;
        const member = me && me.memberships && me.memberships.includes(t.clanId);
        const label = member ? (t.label || clan.name) : clan.name;
        const tw = ctx.measureText(label).width;
        ctx.fillStyle = T.overlay;
        ctx.fillRect(s.sx - tw / 2 - 4 * dpr, s.sy - rPx - 18 * dpr, tw + 8 * dpr, 16 * dpr);
        ctx.fillStyle = T.text;
        ctx.fillText(label, s.sx - tw / 2, s.sy - rPx - 6 * dpr);
      }
    }

    /* Marker: private + Clan-Marker (nur eigene Clans) */
    const visMarkers = [
      ...privMarkers.map((m) => ({ ...m, kind: "privat" })),
      ...clanMarkers.filter((m) => me && me.memberships && me.memberships.includes(m.clanId)).map((m) => ({ ...m, kind: "clan" })),
    ];
    ctx.font = `${14 * dpr}px Inter, system-ui, sans-serif`;
    for (const m of visMarkers) {
      if (m.dim !== dimRef.current) continue;
      const p = w2i(m.x, m.z);
      const s = toS(p.ix, p.iy);
      if (s.sx < -60 * dpr || s.sy < -60 * dpr || s.sx > cv.width + 60 * dpr || s.sy > cv.height + 60 * dpr) continue;
      const u = 2.6 * dpr;
      const clan = m.kind === "clan" ? clans.find((c) => c.id === m.clanId) : null;
      const flagCol = clan ? clan.color : T.accent;
      ctx.fillStyle = T.border;
      ctx.fillRect(s.sx - u, s.sy - 10.5 * u, 2 * u, 11 * u);
      ctx.fillRect(s.sx - u, s.sy - 10.5 * u, 7 * u, 5.5 * u);
      ctx.fillStyle = T.btn;
      ctx.fillRect(s.sx - 0.5 * u, s.sy - 10 * u, u, 10 * u);
      ctx.fillStyle = flagCol;
      ctx.fillRect(s.sx + 0.5 * u, s.sy - 10 * u, 5 * u, 4.5 * u);
      ctx.beginPath();
      ctx.arc(s.sx, s.sy, 1.4 * u, 0, Math.PI * 2);
      ctx.fillStyle = T.border;
      ctx.fill();
      const tw = ctx.measureText(m.name).width;
      ctx.fillStyle = T.overlay;
      ctx.fillRect(s.sx + 7.5 * u, s.sy - 9.5 * u, tw + 8 * dpr, 17 * dpr);
      ctx.fillStyle = T.text;
      ctx.fillText(m.name, s.sx + 7.5 * u + 4 * dpr, s.sy - 9.5 * u + 13 * dpr);
    }

    /* Kompass bei 0/0 */
    const o = toS((0 - d.worldMin) / d.blocksPerPx, (0 - d.worldMin) / d.blocksPerPx);
    drawCompass(ctx, o.sx, o.sy, cv);

    /* Fadenkreuz */
    const cx = cv.width / 2, cy = cv.height / 2;
    const arm = 12 * dpr, gap = 4 * dpr;
    ctx.lineWidth = 2 * dpr;
    for (const [col, off] of [["rgba(0,0,0,0.75)", 1.5 * dpr], [T.text, 0]]) {
      ctx.strokeStyle = col;
      ctx.beginPath();
      ctx.moveTo(cx - arm, cy + off); ctx.lineTo(cx - gap, cy + off);
      ctx.moveTo(cx + gap, cy + off); ctx.lineTo(cx + arm, cy + off);
      ctx.moveTo(cx + off, cy - arm); ctx.lineTo(cx + off, cy - gap);
      ctx.moveTo(cx + off, cy + gap); ctx.lineTo(cx + off, cy + arm);
      ctx.stroke();
    }

    /* Massstab */
    const bpDev = d.blocksPerPx * v.scale;
    const targets = [10, 16, 32, 50, 100, 250, 500, 1000, 2500, 5000, 10000];
    let blocks = targets[targets.length - 1];
    for (const t of targets) { if (t / bpDev >= 60 * dpr) { blocks = t; break; } }
    const L = blocks / bpDev;
    if (L <= 220 * dpr) {
      const bx = 12 * dpr, by = cv.height - 16 * dpr;
      ctx.strokeStyle = T.border; ctx.lineWidth = 5 * dpr;
      ctx.beginPath(); ctx.moveTo(bx, by); ctx.lineTo(bx + L, by); ctx.stroke();
      ctx.strokeStyle = T.text; ctx.lineWidth = 2.5 * dpr;
      ctx.beginPath();
      ctx.moveTo(bx, by); ctx.lineTo(bx + L, by);
      ctx.moveTo(bx, by - 5 * dpr); ctx.lineTo(bx, by + 5 * dpr);
      ctx.moveTo(bx + L, by - 5 * dpr); ctx.lineTo(bx + L, by + 5 * dpr);
      ctx.stroke();
      ctx.font = `${14 * dpr}px Inter, system-ui, sans-serif`;
      const lb = blocks + " Blöcke";
      const tw = ctx.measureText(lb).width;
      ctx.fillStyle = T.overlay;
      ctx.fillRect(bx, by - 26 * dpr, tw + 8 * dpr, 17 * dpr);
      ctx.fillStyle = T.text;
      ctx.fillText(lb, bx + 4 * dpr, by - 13 * dpr);
    }
  }, [imgs, clans, terrs, clanMarkers, privMarkers, me, showGrid, sel, T]);

  function drawCompass(ctx, x, y, cv) {
    const dpr = devicePixelRatio;
    const N = 15, cell = 3.2 * dpr, half = (N * cell) / 2;
    if (x < -half * 2 || y < -half * 2 || x > cv.width + half * 2 || y > cv.height + half * 2) return;
    const c = (N - 1) / 2;
    const px = (i) => Math.round(x - half + i * cell);
    const py = (j) => Math.round(y - half + j * cell);
    const cs = Math.ceil(cell);
    for (let j = 0; j < N; j++) for (let i = 0; i < N; i++) {
      const dx = i - c, dy = j - c, dd = Math.hypot(dx, dy);
      let col = null;
      if (dd <= 4.1) col = "#14141C";
      else if (dd <= 6.1) col = dx + dy < -1 ? "#BDBDBD" : "#868686";
      else if (dd <= 7.2) col = "#2B2A27";
      if (!col) continue;
      ctx.fillStyle = col;
      ctx.fillRect(px(i), py(j), cs, cs);
    }
    for (let j = 0; j < N; j++) {
      const dy = j - c;
      if (Math.abs(dy) > 4) continue;
      ctx.fillStyle = dy < 0 ? "#E0342B" : dy > 0 ? "#E8E4DC" : "#7A1710";
      ctx.fillRect(px(c), py(j), cs, cs);
    }
    ctx.fillStyle = "#7A1710";
    ctx.fillRect(px(c - 1), py(c), cs, cs);
    ctx.fillRect(px(c + 1), py(c), cs, cs);
  }

  /* Canvas-Groesse + Neuzeichnen */
  useEffect(() => {
    const resize = () => {
      const cv = canvasRef.current, wr = wrapRef.current;
      if (!cv || !wr) return;
      cv.width = wr.clientWidth * devicePixelRatio;
      cv.height = wr.clientHeight * devicePixelRatio;
      draw();
    };
    resize();
    window.addEventListener("resize", resize);
    return () => window.removeEventListener("resize", resize);
  }, [draw]);
  useEffect(() => { draw(); }, [draw, view, dimKey]);

  /* Beim ersten Bild der aktiven Dimension einpassen */
  const fitted = useRef({});
  useEffect(() => {
    if (img && !fitted.current[dimKey]) {
      fitted.current[dimKey] = true;
      fitView(img);
    }
  }, [img, dimKey]); // eslint-disable-line

  /* ---------------- Eingabe ---------------- */

  function localPos(e) {
    const r = canvasRef.current.getBoundingClientRect();
    return { px: e.clientX - r.left, py: e.clientY - r.top };
  }
  function pointerToWorldPos(px, py) {
    const cv = canvasRef.current;
    const ix = view.cx + (px * devicePixelRatio - cv.width / 2) * view.scale;
    const iy = view.cy + (py * devicePixelRatio - cv.height / 2) * view.scale;
    return { wx: dim.worldMin + ix * dim.blocksPerPx, wz: dim.worldMin + iy * dim.blocksPerPx };
  }
  function onDown(px, py) {
    dragRef.current = { x: px, y: py, cx: view.cx, cy: view.cy, moved: false };
  }
  function onMove(px, py) {
    const dr = dragRef.current;
    if (!dr) return;
    if (Math.abs(px - dr.x) > 4 || Math.abs(py - dr.y) > 4) dr.moved = true;
    const v = viewRef.current;
    const c = clampCenter(
      dr.cx - (px - dr.x) * devicePixelRatio * v.scale,
      dr.cy - (py - dr.y) * devicePixelRatio * v.scale
    );
    // Sofort zeichnen, aber hoechstens einmal pro Bild - sonst ruckelt es
    viewRef.current = { ...v, cx: c.cx, cy: c.cy };
    if (!rafRef.current) {
      rafRef.current = requestAnimationFrame(() => {
        rafRef.current = null;
        setView(viewRef.current);
      });
    }
  }
  function onUp(px, py) {
    const dr = dragRef.current;
    dragRef.current = null;
    if (rafRef.current) { cancelAnimationFrame(rafRef.current); rafRef.current = null; }
    // Nach dem Ziehen den Zustand einmal nachziehen
    if (dr && dr.moved) setView({ ...viewRef.current });
    if (!dr || dr.moved || px == null) return;
    if (drawClanId) {
      claimTerritory(px, py);
    } else {
      tapSelect(px, py);
    }
  }
  function tapSelect(px, py) {
    const dpr = devicePixelRatio;
    const cv = canvasRef.current;
    const dx = px * dpr, dy = py * dpr;
    const u = 2.6 * dpr;
    const toS = (ix, iy) => ({ sx: (ix - view.cx) / view.scale + cv.width / 2, sy: (iy - view.cy) / view.scale + cv.height / 2 });
    const all = [
      ...privMarkers.map((m) => ({ ...m, kind: "privat" })),
      ...clanMarkers.filter((m) => isMember(m.clanId)).map((m) => ({ ...m, kind: "clan" })),
    ];
    const mHit = [...all].reverse().find((m) => {
      if (m.dim !== dimKey) return false;
      const p = worldToImg(m.x, m.z);
      const s = toS(p.ix, p.iy);
      return Math.hypot(dx - s.sx, dy - (s.sy - 5 * u)) < 20 * dpr;
    });
    if (mHit) { setSel({ type: "marker", obj: mHit }); return; }
    const w = pointerToWorldPos(px, py);
    const tHit = [...terrs].reverse().find((t) =>
      t.dim === dimKey && Math.hypot(w.wx - t.x, w.wz - t.z) <= (t.r || TERR_RADIUS)
    );
    setSel(tHit ? { type: "terr", obj: tHit } : null);
  }

  function onMouseDown(e) { const p = localPos(e); onDown(p.px, p.py); }
  function onMouseMove(e) { if (dragRef.current) { const p = localPos(e); onMove(p.px, p.py); } }
  function onMouseUp(e) { const p = localPos(e); onUp(p.px, p.py); }
  function onWheel(e) {
    e.preventDefault();
    setView((v) => ({ ...v, scale: clamp(v.scale * (e.deltaY > 0 ? 1.18 : 1 / 1.18), 0.04, 40) }));
  }
  const lastTouch = useRef(null);
  function onTouchStart(e) {
    if (e.touches.length === 1) {
      const p = localPos(e.touches[0]);
      lastTouch.current = p;
      onDown(p.px, p.py);
    } else dragRef.current = null;
  }
  function onTouchMove(e) {
    e.preventDefault();
    if (e.touches.length === 1) {
      const p = localPos(e.touches[0]);
      lastTouch.current = p;
      onMove(p.px, p.py);
    }
  }
  function onTouchEnd(e) {
    if (e.touches.length === 0) {
      const p = lastTouch.current;
      onUp(p ? p.px : null, p ? p.py : null);
      lastTouch.current = null;
    }
  }

  /* ---------------- Aktionen ---------------- */

  function machTeilenCode() {
    const paket = { clans, territories: terrs, clanMarkers };
    try {
      const code = btoa(unescape(encodeURIComponent(JSON.stringify(paket))));
      setShareCode(code);
      setNote("Teilen-Code erstellt – kopieren und den anderen schicken.");
    } catch (e) {
      setNote("Code konnte nicht erstellt werden.");
    }
  }

  async function nimmTeilenCode() {
    try {
      const roh = JSON.parse(decodeURIComponent(escape(atob(shareCode.trim()))));
      if (!roh || !Array.isArray(roh.clans)) throw new Error("Format");
      const neuClans = [...clans];
      for (const c of roh.clans) if (!neuClans.some((x) => x.id === c.id)) neuClans.push(c);
      const neuTerrs = [...terrs];
      for (const t of (roh.territories || [])) if (!neuTerrs.some((x) => x.id === t.id)) neuTerrs.push(t);
      const neuMarker = [...clanMarkers];
      for (const m of (roh.clanMarkers || [])) if (!neuMarker.some((x) => x.id === m.id)) neuMarker.push(m);
      setClans(neuClans); setTerrs(neuTerrs); setClanMarkers(neuMarker);
      await sSet(K.clans, neuClans, true);
      await sSet(K.terrs, neuTerrs, true);
      await sSet(K.clanMarkers, neuMarker, true);
      setShareCode("");
      setNote(`Übernommen: ${roh.clans.length} Clans, ${(roh.territories || []).length} Gebiete.`);
    } catch (e) {
      setNote("Der Code konnte nicht gelesen werden.");
    }
  }

  async function speicherTest() {
    const zeit = Date.now();
    lastStorageError = "";
    const pSchreib = await sSet("tc2:selftest", zeit, false);
    const pFehler = lastStorageError;
    const pLese = await sGet("tc2:selftest", false);
    lastStorageError = "";
    const sSchreib = await sSet("tc2:selftest", zeit, true);
    const sFehler = lastStorageError;
    const sLese = await sGet("tc2:selftest", true);
    const teil = (schreib, lese, fehler) =>
      schreib && lese === zeit ? "OK" : !schreib ? `Schreiben fehlgeschlagen${fehler ? " (" + fehler + ")" : ""}` : "Lesen weicht ab";
    setNote(`Selbsttest — Persönlich: ${teil(pSchreib, pLese, pFehler)} · Geteilt: ${teil(sSchreib, sLese, sFehler)}`);
    setStorageBroken(!sSchreib);
  }

  async function saveTheme(k) {
    setThemeKey(k);
    await sSet("tc2:theme", k, false);
  }

  async function saveMe(next) {
    setMe(next);
    await sSet(K.me, next, false);
  }

  async function createClan() {
    const name = newClan.name.trim();
    const code = newClan.code.trim();
    if (!name || !code) { setNote("Clan braucht Name und Codewort."); return; }
    const clan = {
      id: uid("c"), name, color: newClan.color,
      description: newClan.desc.trim(), codeHash: hashCode(code), by: me.name,
    };
    const next = await mutateShared(K.clans, [], (cur) => [...cur, clan]);
    setClans(next);
    await saveMe({ ...me, memberships: [...(me.memberships || []), clan.id] });
    setNewClan({ name: "", desc: "", code: "", color: CLAN_COLORS[0] });
    setNote("Clan erstellt - du bist Mitglied.");
  }

  async function joinClan(clan) {
    const code = (joinInputs[clan.id] || "").trim();
    if (hashCode(code) !== clan.codeHash) { setNote("Falsches Codewort für " + clan.name + "."); return; }
    await saveMe({ ...me, memberships: [...(me.memberships || []), clan.id] });
    setJoinInputs((p) => ({ ...p, [clan.id]: "" }));
    setNote("Du bist " + clan.name + " beigetreten.");
  }

  async function leaveClan(clanId) {
    await saveMe({ ...me, memberships: (me.memberships || []).filter((id) => id !== clanId) });
  }

  async function deleteClan(clanId) {
    const nc = await mutateShared(K.clans, [], (cur) => cur.filter((c) => c.id !== clanId));
    const nt = await mutateShared(K.terrs, [], (cur) => cur.filter((t) => t.clanId !== clanId));
    const nm = await mutateShared(K.clanMarkers, [], (cur) => cur.filter((m) => m.clanId !== clanId));
    setClans(nc); setTerrs(nt); setClanMarkers(nm);
    setConfirmDel(null);
  }

  async function claimTerritory(px, py) {
    const w = pointerToWorldPos(px, py);
    const clan = clans.find((c) => c.id === drawClanId);
    if (!clan) { setDrawClanId(null); return; }
    const count = terrs.filter((t) => t.clanId === clan.id).length + 1;
    const terr = {
      id: uid("t"), clanId: clan.id, dim: dimKey,
      x: Math.round(w.wx), z: Math.round(w.wz), r: TERR_RADIUS,
      label: clan.name + " Gebiet " + count, by: me.name,
    };
    const next = await mutateShared(K.terrs, [], (cur) => [...cur, terr]);
    setTerrs(next);
    setDrawClanId(null);
  }

  async function deleteTerr(t) {
    const next = await mutateShared(K.terrs, [], (cur) => cur.filter((q) => q.id !== t.id));
    setTerrs(next);
    setSel(null);
  }

  async function saveMarker() {
    const c = centerWorld();
    const name = (markerName.trim() || "Marker").slice(0, 40);
    if (markerVis === "privat") {
      const m = { id: uid("m"), dim: dimKey, x: c.x, z: c.z, name };
      const next = [...privMarkers, m];
      setPrivMarkers(next);
      await sSet(K.privMarkers, next, false);
    } else {
      const m = { id: uid("m"), dim: dimKey, x: c.x, z: c.z, name, clanId: markerVis, by: me.name };
      const next = await mutateShared(K.clanMarkers, [], (cur) => [...cur, m]);
      setClanMarkers(next);
    }
    setMarkerDlg(false);
    setMarkerName("");
  }

  async function deleteMarker(m) {
    if (m.kind === "privat") {
      const next = privMarkers.filter((q) => q.id !== m.id);
      setPrivMarkers(next);
      await sSet(K.privMarkers, next, false);
    } else {
      const next = await mutateShared(K.clanMarkers, [], (cur) => cur.filter((q) => q.id !== m.id));
      setClanMarkers(next);
    }
    setSel(null);
  }

  async function uploadMap(d, file) {
    if (uploading) return;
    setUploading(true);
    const P = UPLOAD_PROFIL;

    let url = null;
    try {
      setNote("Bild wird vorbereitet ...");
      url = await fileToDataUrl(file, P.maxDim, P.maxBytes);
    } catch (e) {
      setNote(e && e.message === "zu_gross"
        ? "Das Bild ist zu groß. Nimm bitte die mitgelieferte, kleinere Kartendatei."
        : "Das Bild konnte nicht gelesen werden.");
      setUploading(false);
      return;
    }

    // Karte sofort auf diesem Geraet verwenden - unabhaengig vom Speicher
    setMapUrls((p) => ({ ...p, [d]: url }));
    setImgs((p) => ({ ...p, [d]: undefined }));

    try {
      setNote("Karte wird geteilt ...");
      await saveMapImage(d, url, P.chunk, P.pause, (i, n) => setNote(`Karte wird geteilt ... ${i}/${n}`));
      setNote(DIMS[d].label + "-Karte geteilt – alle sehen sie jetzt.");
    } catch (e) {
      const grund = lastStorageError || (e && e.message) || "unbekannt";
      setNote(`Karte ist hier aktiv, konnte aber nicht geteilt werden (${grund}). Die anderen müssen sie selbst laden.`);
    }
    setUploading(false);
  }

