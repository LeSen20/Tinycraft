            <button style={{ ...S.btn, padding: "5px 12px" }} onClick={createClan}>Clan gründen</button>

            <div className="text-sm font-semibold uppercase tracking-wide mt-5 mb-2" style={{ color: T.dim }}>Clans ({clans.length})</div>
            {clans.length === 0 && <div style={{ color: T.dim }}>Noch keine Clans.</div>}
            {clans.map((clan) => {
              const member = isMember(clan.id);
              const clanTerrs = terrs.filter((t) => t.clanId === clan.id);
              return (
                <div key={clan.id} className="py-2" style={{ borderTop: `1px solid ${T.border}` }}>
                  <div className="flex items-center gap-2">
                    <span className="w-4 h-4 flex-shrink-0" style={{ background: clan.color }} />
                    <span className="text-lg flex-1" style={{ color: clan.color }}>{clan.name}</span>
                    {member && <span className="text-sm px-1" style={{ background: T.active, color: T.text }}>Mitglied</span>}
                    {member && (
                      confirmDel === clan.id
                        ? <button style={{ ...S.btn, padding: "2px 8px", background: T.danger, color: T.text, fontSize: 15 }} onClick={() => deleteClan(clan.id)}>Wirklich?</button>
                        : <button style={{ ...S.btn, padding: "2px 6px", fontSize: 15 }} onClick={() => setConfirmDel(clan.id)}><Trash2 size={13} /></button>
                    )}
                  </div>
                  {clan.description && <div className="text-base ml-6" style={{ color: T.dim }}>{clan.description}</div>}
                  {member ? (
                    <div className="ml-6 mt-1 flex items-center gap-2 overflow-x-auto pb-1" style={{ flexWrap: "nowrap", touchAction: "pan-x", WebkitOverflowScrolling: "touch", overscrollBehavior: "contain" }}>
                      <button style={{ ...S.btn, padding: "3px 10px", fontSize: 16, flexShrink: 0, whiteSpace: "nowrap" }}
                        onClick={() => { setDrawClanId(clan.id); setPanelOpen(false); setSel(null); }}>
                        <Crosshair size={13} className="inline mr-1" />Gebiet beanspruchen ({dim.label})
                      </button>
                      <button style={{ ...S.btn, padding: "3px 10px", fontSize: 16, flexShrink: 0, whiteSpace: "nowrap" }}
                        onClick={() => leaveClan(clan.id)}>Verlassen</button>
                      {clanTerrs.map((t) => (
                        <span key={t.id} className="flex items-center" style={{ flexShrink: 0 }}>
                          <button
                            style={{ ...S.btn, padding: "3px 8px", fontSize: 16, whiteSpace: "nowrap", borderRight: "none", background: T.text2 }}
                            onClick={() => { if (t.dim !== dimKey) setDimKey(t.dim); setTimeout(() => centerOn(t.x, t.z), 0); setPanelOpen(false); setSel({ type: "terr", obj: t }); }}>
                            <Flag size={12} className="inline mr-1" style={{ color: clan.color }} />
                            {t.label} ({DIMS[t.dim].label})
                          </button>
                          <button style={{ ...S.btn, padding: "3px 6px", fontSize: 14, background: T.danger, color: T.text }}
                            title="Gebiet löschen" onClick={() => deleteTerr(t)}><X size={12} /></button>
                        </span>
                      ))}
                    </div>
                  ) : (
                    <div className="ml-6 mt-1 flex gap-2 items-center">
                      <input
                        style={{ ...S.input, width: 150 }} placeholder="Codewort"
                        value={joinInputs[clan.id] || ""}
                        onChange={(e) => setJoinInputs((p) => ({ ...p, [clan.id]: e.target.value }))}
                        onKeyDown={(e) => e.key === "Enter" && joinClan(clan)}
                      />
                      <button style={{ ...S.btn, padding: "3px 10px", fontSize: 16 }} onClick={() => joinClan(clan)}>
                        <LogIn size={13} className="inline mr-1" />Beitreten
                      </button>
                    </div>
                  )}
                </div>
              );
            })}

