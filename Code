            { I: Plus, l: "Näher", f: () => setView((v) => ({ ...v, scale: clamp(v.scale / 1.4, 0.04, 40) })) },
            { I: Minus, l: "Weiter", f: () => setView((v) => ({ ...v, scale: clamp(v.scale * 1.4, 0.04, 40) })) },
            { I: Home, l: "0/0", f: homeView },
            { I: Grid3x3, l: "Chunks", f: () => setShowGrid(!showGrid), a: showGrid },
            { I: Maximize, l: "Alles", f: () => fitView() },
            { I: MapPin, l: "Marker", f: () => { if (img) { setMarkerDlg(true); setMarkerVis("privat"); setSel(null); } } },
            { I: HelpCircle, l: "Hilfe", f: () => setTutStep(0) },
          ].map(({ I, l, f, a }) => (
            <button
              key={l}
              onClick={f}
              style={{
                ...S.btn, ...(a ? S.btnActive : {}),
                width: 58, height: 48, flexShrink: 0, display: "flex", flexDirection: "column",
                alignItems: "center", justifyContent: "center", gap: 2,
              }}
            >
              <I size={17} />
              <span style={{ fontSize: 12, lineHeight: 1 }}>{l}</span>
            </button>
          ))}
        </div>
      </div>

      {/* Karte */}
      <div ref={wrapRef} className="relative flex-1 min-h-0">
        <canvas
          ref={canvasRef}
          className="block w-full h-full"
          style={{ touchAction: "none", cursor: drawClanId ? "crosshair" : "grab" }}
          onMouseDown={onMouseDown}
          onMouseMove={onMouseMove}
          onMouseUp={onMouseUp}
          onMouseLeave={() => { dragRef.current = null; }}
          onWheel={onWheel}
          onTouchStart={onTouchStart}
          onTouchMove={onTouchMove}
          onTouchEnd={onTouchEnd}
        />

        {/* Karten-Upload, solange sie fehlt */}
        {false && (
          <div className="absolute inset-0 flex items-center justify-center p-4">
            <div style={S.panel} className="p-4 max-w-sm text-center">
              <Upload size={26} className="inline mb-2" color={T.accent} />
              <div className="text-lg mb-2">
                Die {dim.label}-Karte wurde noch nicht hochgeladen. Einer aus eurer Gruppe lädt sie einmal hoch - danach sehen sie alle.
              </div>
              <label style={{ ...S.btn, padding: "6px 12px", display: "inline-block" }}>
                {uploading ? "Wird hochgeladen ..." : "Kartenbild wählen"}
                <input type="file" accept="image/*" className="hidden" disabled={uploading} onChange={(e) => e.target.files[0] && uploadMap(dimKey, e.target.files[0])} />
              </label>
            </div>
          </div>
        )}

        {/* Zeichen-Hinweis */}
        {drawClan && (
          <button
            className="absolute top-2 left-1/2 -translate-x-1/2 px-3 py-1 text-base"
            style={{ background: T.overlay, border: `1px solid ${drawClan.color}`, borderRadius: 999, color: T.text, fontFamily: "inherit", boxShadow: "0 8px 24px rgba(0,0,0,.35)" }}
            onClick={() => setDrawClanId(null)}
          >
            Mittelpunkt für „{drawClan.name}“ antippen ({TERR_RADIUS} Blöcke Umkreis) – hier tippen zum Abbrechen
          </button>
