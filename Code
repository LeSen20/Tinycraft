                  {DIMS[k].label}
                </button>
              ))}
            </div>
            <button style={{ ...S.btn, padding: "5px 12px", ...(panelOpen ? S.btnActive : {}) }} onClick={() => { setPanelOpen(!panelOpen); setSel(null); }}>
              <Users size={15} className="inline mr-1" />Clans
            </button>
          </div>
        </div>
        <div className="flex gap-1 px-2 py-2 overflow-x-auto"
          style={{ flexWrap: "nowrap", touchAction: "pan-x", WebkitOverflowScrolling: "touch", overscrollBehavior: "contain" }}>
