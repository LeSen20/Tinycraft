function PixelCompass({ size = 84 }) {
  const ref = useRef(null);
  useEffect(() => {
    const cv = ref.current;
    if (!cv) return;
    const N = 15, cell = size / N;
    cv.width = size; cv.height = size;
    const ctx = cv.getContext("2d");
    const c = (N - 1) / 2;
    for (let j = 0; j < N; j++) for (let i = 0; i < N; i++) {
      const dx = i - c, dy = j - c, d = Math.hypot(dx, dy);
      let col = null;
      if (d <= 4.1) col = "#14141C";
      else if (d <= 6.1) col = dx + dy < -1 ? "#BDBDBD" : "#868686";
      else if (d <= 7.2) col = "#2B2A27";
      if (!col) continue;
      ctx.fillStyle = col;
      ctx.fillRect(Math.round(i * cell), Math.round(j * cell), Math.ceil(cell), Math.ceil(cell));
    }
    for (let j = 0; j < N; j++) {
      const dy = j - c;
      if (Math.abs(dy) > 4) continue;
      ctx.fillStyle = dy < 0 ? "#E0342B" : dy > 0 ? "#E8E4DC" : "#7A1710";
      ctx.fillRect(Math.round(c * cell), Math.round(j * cell), Math.ceil(cell), Math.ceil(cell));
    }
    ctx.fillStyle = "#7A1710";
    ctx.fillRect(Math.round((c - 1) * cell), Math.round(c * cell), Math.ceil(cell), Math.ceil(cell));
    ctx.fillRect(Math.round((c + 1) * cell), Math.round(c * cell), Math.ceil(cell), Math.ceil(cell));
  }, [size]);
  return <canvas ref={ref} style={{ imageRendering: "pixelated", width: size, height: size }} />;
}

