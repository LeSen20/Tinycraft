              </span>
              <button onClick={() => setBannerZu(true)}
                style={{ ...S.btn, padding: "2px 8px", flexShrink: 0 }}>Ok</button>
            </div>
          </div>
        )}

        {note && (
          <div className="absolute top-2 right-2 px-2 py-1 text-base" style={{ background: T.overlay, border: `1px solid ${T.accent}`, borderRadius: 14, boxShadow: "0 10px 30px rgba(0,0,0,.35)" }}
            onClick={() => setNote("")}>
            {note} <X size={12} className="inline ml-1" />
          </div>
        )}

        {/* Tutorial */}
        {tutStep !== null && (() => {
          const st = TUT_STEPS[tutStep];
          const Icon = st.I;
          return (
            <div className="absolute inset-0 flex items-center justify-center p-4" style={{ background: "rgba(0,0,0,0.55)", zIndex: 20 }}>
              <div style={{ ...S.panel }} className="p-5 max-w-sm w-full text-center">
                <Icon size={34} color={T.accent} className="inline" />
                <div className="text-2xl mt-1" style={{ color: T.btn }}>{st.t}</div>
                <div className="text-lg mt-1" style={{ color: T.text2 }}>{st.d}</div>
                <div className="flex justify-center gap-1 my-3">
                  {TUT_STEPS.map((_, i) => (
                    <span key={i} className="w-2 h-2" style={{ background: i === tutStep ? T.accent : T.border }} />
                  ))}
                </div>
                <div className="flex justify-center gap-2">
                  {tutStep > 0 && (
                    <button style={{ ...S.btn, padding: "4px 12px", fontSize: 16 }} onClick={() => setTutStep(tutStep - 1)}>Zurück</button>
                  )}
                  {tutStep < TUT_STEPS.length - 1 ? (
                    <button style={{ ...S.btn, ...S.btnActive, padding: "4px 12px", fontSize: 16 }} onClick={() => setTutStep(tutStep + 1)}>Weiter</button>
                  ) : (
                    <button style={{ ...S.btn, ...S.btnActive, padding: "4px 12px", fontSize: 16 }} onClick={finishTutorial}>Los geht's!</button>
                  )}
                </div>
                <button
                  className="mt-2"
                  style={{ background: "none", border: "none", color: T.dim, fontFamily: "inherit", fontSize: 15, cursor: "pointer", textDecoration: "underline" }}
                  onClick={finishTutorial}
                >
                  Überspringen
                </button>
              </div>
            </div>
          );
        })()}
      </div>

      {/* Koordinaten-Leiste */}
      <div className="flex items-center gap-1 flex-wrap px-2 py-2" style={{ background: T.surface, borderTop: `1px solid ${T.border}` }}>
        <span className="text-lg">X</span>
        <input style={{ ...S.input, width: 78 }} value={gotoX} onChange={(e) => setGotoX(e.target.value)} onKeyDown={(e) => e.key === "Enter" && goTo()} />
        <button style={{ ...S.btn, width: 36, height: 36 }} onClick={() => setGotoX((v) => (v.trim().startsWith("-") ? v.trim().slice(1) : "-" + v.trim()))}>±</button>
        <span className="text-lg">Z</span>
        <input style={{ ...S.input, width: 78 }} value={gotoZ} onChange={(e) => setGotoZ(e.target.value)} onKeyDown={(e) => e.key === "Enter" && goTo()} />
        <button style={{ ...S.btn, width: 36, height: 36 }} onClick={() => setGotoZ((v) => (v.trim().startsWith("-") ? v.trim().slice(1) : "-" + v.trim()))}>±</button>
        <button style={{ ...S.btn, padding: "5px 12px" }} onClick={goTo}>➜ Hin</button>
        <button style={{ ...S.btn, padding: "5px 10px" }} title="Portal-Gegenstück" onClick={portalJump}><ArrowRightLeft size={15} /></button>
        <button style={{ ...S.btn, padding: "5px 10px" }} title="Jetzt synchronisieren" onClick={loadShared}><RefreshCw size={15} /></button>
      </div>
    </div>
  );
}
